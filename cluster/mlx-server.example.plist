<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Edit before installing: replace USERNAME (3 places), and set your model and host IP. -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mlx-server</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/USERNAME/.venvs/mlx/bin/mlx_lm.server</string>
        <string>--model</string>
        <string>mlx-community/Qwen3.6-35B-A3B-4bit-DWQ</string>
        <string>--host</string>
        <string>10.0.0.1</string>
        <string>--port</string>
        <string>8080</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>ThrottleInterval</key>
    <integer>60</integer>
    <key>StandardOutPath</key>
    <string>/Users/USERNAME/Library/Logs/mlx-server.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/USERNAME/Library/Logs/mlx-server.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HF_HUB_OFFLINE</key>
        <string>1</string>
    </dict>
</dict>
</plist>
